rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.uid == userId;
      
      match /savedConfigs/{configId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isOwner(userId);
      }

      match /assets/{assetId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
